{
  "id": null,
  "uid": "dotnet-api-overview",
  "title": "Product Template — API Overview",
  "description": "Dashboard de observabilidade para a API ASP.NET Core — Requisições, Latência, Erros, Runtime .NET",
  "tags": ["dotnet", "aspnetcore", "api", "product-template"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "prometheus" },
        "hide": 0,
        "label": "Datasource"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Taxa de Requisições (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "rate(http_server_request_duration_seconds_count{job=\"product-template-api\"}[2m])",
          "legendFormat": "{{http_request_method}} {{url_scheme}}://{{server_address}}{{http_route}} - {{http_response_status_code}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Latência P50 / P95 / P99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_request_duration_seconds_bucket{job=\"product-template-api\"}[5m])) by (le, http_route, http_request_method))",
          "legendFormat": "p50 {{http_request_method}} {{http_route}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{job=\"product-template-api\"}[5m])) by (le, http_route, http_request_method))",
          "legendFormat": "p95 {{http_request_method}} {{http_route}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_request_duration_seconds_bucket{job=\"product-template-api\"}[5m])) by (le, http_route, http_request_method))",
          "legendFormat": "p99 {{http_request_method}} {{http_route}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 3,
      "title": "Taxa de Erros HTTP 4xx/5xx",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "rate(http_server_request_duration_seconds_count{job=\"product-template-api\", http_response_status_code=~\"4..\"}[2m])",
          "legendFormat": "4xx — {{http_route}}",
          "refId": "A"
        },
        {
          "expr": "rate(http_server_request_duration_seconds_count{job=\"product-template-api\", http_response_status_code=~\"5..\"}[2m])",
          "legendFormat": "5xx — {{http_route}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 4,
      "title": "Memória Heap .NET (MB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "decmbytes"
        }
      },
      "targets": [
        {
          "expr": "dotnet_gc_heap_size_bytes{job=\"product-template-api\"} / 1024 / 1024",
          "legendFormat": "Heap {{generation}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "GC Collections por Geração",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "rate(dotnet_gc_collections_total{job=\"product-template-api\"}[5m])",
          "legendFormat": "GC Gen{{generation}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Thread Pool — Threads Ativos",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "dotnet_thread_pool_thread_count{job=\"product-template-api\"}",
          "legendFormat": "Threads no Pool",
          "refId": "A"
        },
        {
          "expr": "dotnet_thread_pool_queue_length{job=\"product-template-api\"}",
          "legendFormat": "Fila de trabalho",
          "refId": "B"
        }
      ]
    },
    {
      "id": 7,
      "title": "Total de Requisições (últimas 5min)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 24 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(increase(http_server_request_duration_seconds_count{job=\"product-template-api\"}[5m]))",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "% de Erros (últimas 5min)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 24 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "100 * sum(rate(http_server_request_duration_seconds_count{job=\"product-template-api\", http_response_status_code=~\"5..\"}[5m])) / sum(rate(http_server_request_duration_seconds_count{job=\"product-template-api\"}[5m]))",
          "legendFormat": "Erros 5xx",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Latência Mediana (P50)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 24 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_request_duration_seconds_bucket{job=\"product-template-api\"}[5m])) by (le)) * 1000",
          "legendFormat": "P50 (ms)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Memória Total .NET (MB)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 24 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "decmbytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "process_working_set_bytes{job=\"product-template-api\"} / 1024 / 1024",
          "legendFormat": "Working Set",
          "refId": "A"
        }
      ]
    }
  ]
}

